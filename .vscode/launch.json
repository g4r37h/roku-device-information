{
    "version": "0.2.0",
    "configurations": [
        {
            "consoleOutput": "normal",
            "enableDebuggerAutoRecovery": true,
            "enableDebugProtocol": true,
            "envFile": "${workspaceFolder}/.env",
            "host": "${env:DEVELOPMENT_ROKU_IP_1}",
            "name": "Build Production (IP #1)",
            "password": "${env:DEVELOPMENT_ROKU_PASSWORD}",
            "preLaunchTask": "Build Production",
            "request": "launch",
            "stopDebuggerOnAppExit": true,
            "stopOnEntry": false,
            "type": "brightscript",
            "files": [
                "*",
                "*.*",
                "**/*.*"
            ],
            "rootDir": "${workspaceFolder}/build",
            "sourceDirs": [
                "${workspaceFolder}/"
            ]
        }
    ]
}
